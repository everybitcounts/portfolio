---
// RAG-style chatbot — answers recruiter questions about William's experience.
// Calls /api/chat (Vercel serverless function) which uses OpenAI gpt-4o-mini.
---

<!-- Floating chat button -->
<button id="chat-fab" class="chat-fab" aria-label="Ask about William's experience">
  <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
  </svg>
  <span class="chat-fab-label">WillBot</span>
  <span class="chat-fab-badge" id="chat-badge" aria-hidden="true">1</span>
</button>

<!-- Chat popup -->
<div id="chat-panel" class="chat-panel" role="dialog" aria-modal="true" aria-labelledby="chat-panel-title" style="display:none">
  <div class="chat-header">
    <div class="chat-header-left">
      <div class="chat-avatar" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 38 28" width="32" height="24" fill="none">
          <rect x="0" y="11" width="11" height="14" rx="1.8" fill="#7c3aed"/>
          <rect x="0" y="8" width="11" height="14" rx="1.8" fill="#9333ea"/>
          <rect x="0" y="5" width="11" height="14" rx="1.8" fill="#c084fc"/>
          <line x1="2.5" y1="9.5" x2="8.5" y2="9.5" stroke="white" stroke-width="1.1" stroke-linecap="round"/>
          <line x1="2.5" y1="12" x2="8.5" y2="12" stroke="white" stroke-width="1.1" stroke-linecap="round"/>
          <line x1="2.5" y1="14.5" x2="6" y2="14.5" stroke="white" stroke-width="1.1" stroke-linecap="round"/>
          <line x1="12" y1="14" x2="19" y2="14" stroke="#a855f7" stroke-width="1.3" stroke-linecap="round" stroke-dasharray="2 1.3"/>
          <path d="M17.5 11.8 L20 14 L17.5 16.2" stroke="#a855f7" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <rect x="21" y="5" width="17" height="16" rx="3.5" fill="#a855f7"/>
          <circle cx="26.5" cy="13" r="1.7" fill="white"/>
          <circle cx="32.5" cy="13" r="1.7" fill="white"/>
          <path d="M21 21 L26 27 L26 21" fill="#a855f7"/>
          <line x1="29.5" y1="5" x2="29.5" y2="2" stroke="#a855f7" stroke-width="1.6" stroke-linecap="round"/>
          <circle cx="29.5" cy="1" r="1.4" fill="#c084fc"/>
        </svg>
      </div>
      <div>
        <span id="chat-panel-title" class="chat-title">WillBot</span>
        <span class="chat-subtitle">Will's AI career assistant</span>
      </div>
    </div>
    <button id="chat-close" class="chat-close" aria-label="Close chat">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div id="chat-messages" class="chat-messages" role="log" aria-live="polite" aria-label="Conversation">
    <!-- Starter message injected by JS -->
  </div>

  <div class="chat-suggestions" id="chat-suggestions">
    <button class="suggestion-chip" data-q="What is William's current role?">Current role?</button>
    <button class="suggestion-chip" data-q="Tell me about ShieldNet and Terraform Academy.">His products?</button>
    <button class="suggestion-chip" data-q="What cloud certifications or skills does William have?">Cloud skills?</button>
    <button class="suggestion-chip" data-q="Is William open to new opportunities?">Open to work?</button>
  </div>

  <form id="chat-form" class="chat-input-row" autocomplete="off" novalidate>
    <input
      id="chat-input"
      class="chat-input"
      type="text"
      placeholder="Ask about experience, skills, projects…"
      maxlength="300"
      aria-label="Your question"
      autocomplete="off"
    />
    <button type="submit" class="chat-send" aria-label="Send message">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
    </button>
  </form>
</div>

<script>
(function () {
  const fab     = document.getElementById('chat-fab');
  const panel   = document.getElementById('chat-panel');
  const closeBtn= document.getElementById('chat-close');
  const form    = document.getElementById('chat-form');
  const input   = document.getElementById('chat-input');
  const log     = document.getElementById('chat-messages');
  const badge   = document.getElementById('chat-badge');
  const sugBox  = document.getElementById('chat-suggestions');

  // Conversation history for multi-turn context
  const history = [];
  const MAX_CLIENT_TURNS = 15; // hard cap — prevents runaway API costs
  let isOpen = false;
  let isLoading = false;

  function openPanel() {
    isOpen = true;
    panel.style.display = 'flex';
    fab.setAttribute('aria-expanded', 'true');
    badge.style.display = 'none';
    if (history.length === 0) addBotMessage(
      "Hey! 👋 I'm **WillBot** — Will's AI, built on his actual background.\n\nAsk me about his experience, skills, live products, or whether he's taking calls. I'll give you the straight answers."
    );
    requestAnimationFrame(() => input.focus());
  }

  function closePanel() {
    isOpen = false;
    panel.style.display = 'none';
    fab.setAttribute('aria-expanded', 'false');
    fab.focus();
  }

  fab.addEventListener('click', () => isOpen ? closePanel() : openPanel());
  closeBtn.addEventListener('click', closePanel);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closePanel();
  });

  // Suggestion chips
  sugBox.addEventListener('click', (e) => {
    const chip = e.target.closest('.suggestion-chip');
    if (!chip) return;
    const q = chip.dataset.q;
    sendMessage(q);
    sugBox.style.display = 'none';
  });

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text || isLoading) return;
    sendMessage(text);
    input.value = '';
    if (sugBox) sugBox.style.display = 'none';
  });

  function sendMessage(text) {
    // Client-side hard cap to prevent runaway API costs
    const userTurns = history.filter(m => m.role === 'user').length;
    if (userTurns >= MAX_CLIENT_TURNS) {
      addBotMessage("Great conversation — but we've hit the session limit on my end.\n\nTo keep things going, reach out to Will directly:\n\n📧 [WilliamValdez22@gmail.com](mailto:WilliamValdez22@gmail.com)\n\nHe responds quickly. If a call makes more sense, mention it in your email and he'll get one on the calendar.");
      input.disabled = true;
      return;
    }
    addUserMessage(text);
    history.push({ role: 'user', content: text });
    fetchReply();
  }

  function addUserMessage(text) {
    const el = document.createElement('div');
    el.className = 'msg msg-user';
    el.textContent = text;
    log.appendChild(el);
    scrollToBottom();
  }

  function addBotMessage(text) {
    const el = document.createElement('div');
    el.className = 'msg msg-bot';
    el.innerHTML = formatMarkdown(text);
    log.appendChild(el);
    scrollToBottom();
    return el;
  }

  function addThinkingBubble() {
    const el = document.createElement('div');
    el.className = 'msg msg-bot msg-thinking';
    el.innerHTML = '<span class="dot"></span><span class="dot"></span><span class="dot"></span>';
    log.appendChild(el);
    scrollToBottom();
    return el;
  }

  async function fetchReply() {
    isLoading = true;
    input.disabled = true;
    const bubble = addThinkingBubble();

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: history }),
      });

      const data = await res.json();
      bubble.remove();

      if (res.status === 429) {
        if (data.limit_type === 'hour') {
          addBotMessage("Well, this has been quite the conversation! This session has hit its limit — but the best next step is a real one.\n\n📧 [WilliamValdez22@gmail.com](mailto:WilliamValdez22@gmail.com)\n\nShoot Will an email. If a quick call makes more sense, just mention it and he'll get one on the calendar.");
          input.disabled = true;
        } else {
          addBotMessage("⏱️ A few too many messages at once — give it a moment and try again.");
        }
        return;
      }
      if (!res.ok || data.error) {
        addBotMessage('Sorry, something went wrong. Please try again or email WilliamValdez22@gmail.com directly.');
        return;
      }

      history.push({ role: 'assistant', content: data.reply });
      addBotMessage(data.reply);
    } catch {
      bubble.remove();
      addBotMessage('Connection error. Please check your network and try again.');
    } finally {
      isLoading = false;
      input.disabled = false;
      input.focus();
    }
  }

  function scrollToBottom() {
    log.scrollTop = log.scrollHeight;
  }

  // Minimal markdown: **bold**, *italic*, [links](url), bullet lists, line breaks
  function formatMarkdown(text) {
    return text
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.+?)\*/g, '<em>$1</em>')
      .replace(/\[([^\]]+)\]\(((?:https?:|mailto:)[^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>')
      .replace(/^[-•] (.+)$/gm, '<li>$1</li>')
      .replace(/(<li>.*<\/li>\n?)+/gs, m => `<ul>${m}</ul>`)
      .replace(/\n/g, '<br>');
  }
})();
</script>

<style>
  /* ── FAB ── */
  .chat-fab {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 9000;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 20px 14px 16px;
    background: var(--accent, #3b82f6);
    color: #fff;
    border: none;
    border-radius: 50px;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(59,130,246,.45);
    font-size: 0.9rem;
    font-weight: 600;
    transition: transform 0.2s, box-shadow 0.2s;
    font-family: inherit;
  }
  .chat-fab:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(59,130,246,.55);
  }
  .chat-fab-badge {
    position: absolute;
    top: -6px;
    right: -6px;
    width: 20px;
    height: 20px;
    background: #ef4444;
    border-radius: 50%;
    font-size: 0.7rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--bg-primary, #fff);
  }

  /* ── Panel ── */
  .chat-panel {
    position: fixed;
    bottom: 90px;
    right: 28px;
    z-index: 9001;
    width: 380px;
    max-width: calc(100vw - 32px);
    max-height: 560px;
    display: flex;
    flex-direction: column;
    background: var(--card-bg, #18181b);
    border: 1px solid var(--card-border, rgba(255,255,255,.08));
    border-radius: 20px;
    box-shadow: 0 24px 60px rgba(0,0,0,.4);
    overflow: hidden;
    animation: chatSlideUp .22s ease;
  }

  @keyframes chatSlideUp {
    from { opacity: 0; transform: translateY(16px) scale(.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ── Header ── */
  .chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    background: linear-gradient(135deg, #7c3aed 0%, var(--accent, #3b82f6) 100%);
    flex-shrink: 0;
  }
  .chat-header-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .chat-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255,255,255,.15);
    border-radius: 12px;
    flex-shrink: 0;
  }
  .chat-title {
    display: block;
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    line-height: 1.2;
  }
  .chat-subtitle {
    display: block;
    color: rgba(255,255,255,.7);
    font-size: 0.72rem;
  }
  .chat-close {
    background: rgba(255,255,255,.15);
    border: none;
    border-radius: 8px;
    color: #fff;
    cursor: pointer;
    padding: 6px;
    display: flex;
    align-items: center;
    transition: background 0.15s;
  }
  .chat-close:hover { background: rgba(255,255,255,.25); }

  /* ── Messages ── */
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    scroll-behavior: smooth;
  }
  .chat-messages::-webkit-scrollbar { width: 4px; }
  .chat-messages::-webkit-scrollbar-thumb { background: var(--card-border, rgba(255,255,255,.1)); border-radius: 4px; }

  .msg {
    max-width: 90%;
    padding: 10px 14px;
    border-radius: 16px;
    font-size: 0.875rem;
    line-height: 1.55;
    word-break: break-word;
  }
  .msg-user {
    align-self: flex-end;
    background: var(--accent, #3b82f6);
    color: #fff;
    border-bottom-right-radius: 4px;
  }
  .msg-bot {
    align-self: flex-start;
    background: var(--bg-tertiary, #27272a);
    color: var(--text-primary, #fafafa);
    border-bottom-left-radius: 4px;
  }
  .msg-bot ul {
    padding-left: 18px;
    margin: 4px 0;
  }
  .msg-bot li { margin: 2px 0; }

  /* Thinking dots */
  .msg-thinking {
    display: flex;
    gap: 5px;
    align-items: center;
    padding: 12px 16px;
  }
  .msg-thinking .dot {
    width: 7px;
    height: 7px;
    background: var(--text-muted, #71717a);
    border-radius: 50%;
    animation: bounce 1.2s infinite;
  }
  .msg-thinking .dot:nth-child(2) { animation-delay: .2s; }
  .msg-thinking .dot:nth-child(3) { animation-delay: .4s; }
  @keyframes bounce {
    0%, 80%, 100% { transform: translateY(0); }
    40%           { transform: translateY(-6px); }
  }

  /* ── Suggestion chips ── */
  .chat-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0 16px 10px;
    flex-shrink: 0;
  }
  .suggestion-chip {
    padding: 5px 12px;
    border: 1px solid var(--card-border, rgba(255,255,255,.1));
    border-radius: 20px;
    background: transparent;
    color: var(--text-secondary, #a1a1aa);
    font-size: 0.78rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.15s;
  }
  .suggestion-chip:hover {
    border-color: var(--accent, #3b82f6);
    color: var(--accent, #3b82f6);
    background: color-mix(in srgb, var(--accent, #3b82f6) 10%, transparent);
  }

  /* ── Input row ── */
  .chat-input-row {
    display: flex;
    gap: 8px;
    padding: 12px 14px;
    border-top: 1px solid var(--card-border, rgba(255,255,255,.06));
    background: var(--bg-secondary, #111);
    flex-shrink: 0;
  }
  .chat-input {
    flex: 1;
    background: var(--bg-tertiary, #27272a);
    border: 1px solid var(--card-border, rgba(255,255,255,.08));
    border-radius: 10px;
    padding: 9px 14px;
    color: var(--text-primary, #fafafa);
    font-size: 0.875rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s;
  }
  .chat-input::placeholder { color: var(--text-muted, #71717a); }
  .chat-input:focus { border-color: var(--accent, #3b82f6); }
  .chat-input:disabled { opacity: 0.5; }

  .chat-send {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--accent, #3b82f6);
    border: none;
    border-radius: 10px;
    color: #fff;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.15s, transform 0.15s;
  }
  .chat-send:hover { background: var(--accent-hover, #60a5fa); transform: scale(1.05); }

  /* ── Mobile ── */
  @media (max-width: 480px) {
    .chat-panel {
      right: 12px;
      bottom: 80px;
      width: calc(100vw - 24px);
      max-height: 70vh;
    }
    .chat-fab { bottom: 16px; right: 16px; }
    .chat-fab-label { display: none; }
    .chat-fab { padding: 16px; border-radius: 50%; }
  }
</style>
