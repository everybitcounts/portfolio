---
const GITHUB_BASE = "https://github.com/everybitcounts";
const MONO_REPO = `${GITHUB_BASE}/public-projects`;

interface Project {
  id: string;
  title: string;
  description: string;
  category: string;
  tags: string[];
  github: string;
  isStandalone?: boolean;
  features: string[];
  architecture: {
    type: string;
    components: { name: string; layer: string }[];
  };
}

interface ProjectGroup {
  id: string;
  title: string;
  subtitle: string;
  icon: string;
  accentColor: string;
  defaultOpen: boolean;
  projects: Project[];
}

const groups: ProjectGroup[] = [
  {
    id: "ai-platform",
    title: "AI & Platform Innovation",
    subtitle: "AI-native SDLC transformation, agentic workflows, and developer productivity",
    icon: "🤖",
    accentColor: "#a855f7",
    defaultOpen: true,
    projects: [
      {
        id: "ai-sdlc-toolkit",
